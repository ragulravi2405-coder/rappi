{
  "name": "smart-gpt",
  "version": "1.0.0",
  "description": "SmartGPT - Full-stack AI Chat App with Flutter frontend and Node.js Express backend",
  "scripts": {
    "build": "npm install --prefix backend",
    "start": "npm start --prefix backend",
    "dev": "npm run dev --prefix backend",
    "install:backend": "npm install --prefix backend",
    "start:backend": "npm start --prefix backend",
    "dev:backend": "npm run dev --prefix backend",
    "frontend": "cd frontend && flutter run",
    "frontend:web": "cd frontend && flutter run -d chrome"
  }
}
